# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron Jobs
CRON_SECRET=change_me_in_production
NEXT_PUBLIC_CRON_SECRET=change_me_in_production

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM="VendingPro <financeiro@vendingpro.com.br>"
EMAIL_SUPPORT=suporte@vendingpro.com.br

# Gateway de Pagamento (Asaas)
ASAAS_API_KEY=your_asaas_api_key
ASAAS_ENV=sandbox
ASAAS_WEBHOOK_TOKEN=change_me_to_random_string
